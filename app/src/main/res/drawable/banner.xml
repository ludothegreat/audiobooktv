<?xml version="1.0" encoding="utf-8"?>
<!--
    Android TV launcher banner.

    Keeps the existing Gruvbox palette and layout, but replaces the
    hand-built rectangle glyphs with a cleaner rounded monoline wordmark.

    Background      #1d2021
    Accent line     #98971a
    Three-bar mark  #b8bb26
    Wordmark        #ebdbb2

    The Onn TV launcher caches this image across reinstalls; a full TV
    reboot is required to see edits take effect on-device.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Background -->
    <path
        android:fillColor="#1d2021"
        android:pathData="M0,0h320v180h-320z" />

    <!-- Bottom accent rule, rounded so it feels less like a debug rectangle -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#98971a"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M40,159H280" />

    <!-- Three-bar mark -->
    <path
        android:fillColor="#b8bb26"
        android:pathData="M40,60h16v60h-16zM62,60h16v60h-16zM84,60h16v60h-16z" />

    <!--
        abTV wordmark.
        Rounded monoline paths read cleaner at TV banner size than the
        earlier rectangle-built glyphs. Stroke width is intentionally
        heavier than before so the wordmark visually balances the mark.
    -->

    <!-- a -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#ebdbb2"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M128,82H160V120H128V98H160" />

    <!-- b -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#ebdbb2"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M178,60V120H212V88H178" />

    <!-- T -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#ebdbb2"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M226,60H262M244,60V120" />

    <!-- V -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#ebdbb2"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M272,60L288,120L304,60" />

</vector>
