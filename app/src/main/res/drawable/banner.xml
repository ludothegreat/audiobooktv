<?xml version="1.0" encoding="utf-8"?>
<!--
    Android TV launcher banner.

    Rounded monoline wordmark + three-bar mark, shifted 14dp left of
    the previous layout so the wider monoline glyphs center cleanly
    in the banner.

    Background      #1d2021
    Accent line     #98971a
    Three-bar mark  #b8bb26
    Wordmark        #ebdbb2

    The Onn TV launcher caches this image across reinstalls; a full TV
    reboot is required to see edits take effect on-device.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Background -->
    <path
        android:fillColor="#1d2021"
        android:pathData="M0,0h320v180h-320z" />

    <!-- Bottom accent rule: unchanged -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#98971a"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M40,159H280" />

    <!-- Three-bar mark: shifted left 14 -->
    <path
        android:fillColor="#b8bb26"
        android:pathData="M26,60h16v60h-16zM48,60h16v60h-16zM70,60h16v60h-16z" />

    <!-- a: shifted left 14 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#ebdbb2"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M114,82H146V120H114V98H146" />

    <!-- b: shifted left 14 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#ebdbb2"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M164,60V120H198V88H164" />

    <!-- T: shifted left 14 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#ebdbb2"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M212,60H248M230,60V120" />

    <!-- V: shifted left 14 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#ebdbb2"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M258,60L274,120L290,60" />

</vector>
